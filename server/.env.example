# ── Spelling Bee ──────────────────────────────────────────────
# Required: RapidAPI key for WordsAPI (https://rapidapi.com/dpventures/api/wordsapi)
WORDSAPI_KEY=your_rapidapi_key_here
WORDSAPI_HOST=wordsapiv1.p.rapidapi.com

# Optional: Google Cloud TTS — path to your service account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=path/to/your-service-account-key.json

# ── Ports (defaults shown) ───────────────────────────────────
CHESS_PORT=3004
TICTACTOE_PORT=3001
CHROMA_MEMORY_PORT=3002

# Spelling Bee server reads PORT (not SPELLING_BEE_PORT)
PORT=8787
