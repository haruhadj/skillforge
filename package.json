    "lucide-react": "^1.18.0",
    "next": "^16.2.6",
    "node-sqlite3-wasm": "0.8.57",
    "radix-ui": "^1.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "resend": "^6.12.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
