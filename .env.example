NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyA1a0RcoGmHgIx8GJ9QD3-BC3z-3RopL1k
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=skillforge-7a058.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=skillforge-7a058
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=skillforge-7a058.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=594339083725
NEXT_PUBLIC_FIREBASE_APP_ID=1:594339083725:web:54037350180ae6d4e54084

# ── Google OAuth (server-side sign-in) ───────────────────────
# Create credentials at: Google Cloud Console > APIs & Services > Credentials
# Authorized redirect URI (local):  http://localhost:3000/api/auth/callback/google
# Authorized redirect URI (prod):   https://yourdomain.com/api/auth/callback/google
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxx

# ── GitHub OAuth (server-side sign-in) ───────────────────────
# Create an OAuth App at: GitHub > Settings > Developer settings > OAuth Apps
# Authorization callback URL (local):  http://localhost:3000/api/auth/callback/github
# Authorization callback URL (prod):   https://yourdomain.com/api/auth/callback/github
GITHUB_OAUTH_CLIENT_ID=Iv1.xxxxxxxx
GITHUB_OAUTH_CLIENT_SECRET=xxxxxxxx

# ── TikTok OAuth (server-side sign-in) ───────────────────────
# Create an app at: TikTok for Developers > Manage apps > Login Kit
# Add the "user.info.basic" scope. TikTok requires an HTTPS redirect URI in
# production and does NOT return an email. Uses client_key, not client_id.
# Redirect URI (local):  http://localhost:3000/api/auth/callback/tiktok
# Redirect URI (prod):   https://yourdomain.com/api/auth/callback/tiktok
TIKTOK_OAUTH_CLIENT_KEY=xxxxxxxx
TIKTOK_OAUTH_CLIENT_SECRET=xxxxxxxx

# Public base URL of the app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Resend Email Service ────────────────────────────────────
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Firebase Admin SDK ────────────────────────────────────────
# Option 1: Full service account JSON (preferred)
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Option 2: Individual fields (alternative)
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@skillforge-7a058.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: chess multiplayer socket base URL.
# Local dev fallback is http://localhost:3004.
# Production fallback is current site origin (recommended behind reverse proxy).
# NEXT_PUBLIC_CHESS_SOCKET_URL=https://skillforge.haruhadj.duckdns.org


# ── Spelling Bee ──────────────────────────────────────────────
# Optional: Google Cloud TTS — path to your service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=server/tts-key.json

# ── Ports (defaults shown) ───────────────────────────────────
CHESS_PORT=3004
TICTACTOE_PORT=3001
CHROMA_MEMORY_PORT=3002

# Spelling Bee server reads PORT (not SPELLING_BEE_PORT)
PORT=8787

# ── Vocab / Hangman WordNet API ────────────────────────────
# Vocab API server port (default: 8788)
VOCAB_PORT=8788
VOCAB_HOST=0.0.0.0

# Internal API origin for Spelling Bee to reach Vocab service
# In Docker: http://vocab:8788
# Local dev: http://localhost:8788
VOCAB_API_ORIGIN=http://localhost:8788
