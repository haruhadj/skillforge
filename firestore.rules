rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // True only when the *caller* already holds the admin role. Reads the caller's
    // own user doc, so it cannot be spoofed by writing the target document.
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // True when the incoming write does not touch privileged fields. `role` is the
    // sole admin marker (see app/api/admin/delete-user/route.ts) and must never be
    // self-assignable; gate any future privilege fields here too.
    function noPrivilegeEscalation() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
    }

    // Owner subcollection access. These matches require at least one path segment
    // below users/{uid}, so they can never grant write access to the root profile doc
    // — that is governed solely by the `match /users/{uid}` block below, which guards
    // the `role` field. Without this separation, a recursive `{document=**}` rule would
    // let any signed-in user write `role: 'admin'` onto their own profile.
    //
    // S2: scores are SERVER-AUTHORITATIVE. The client may read its own scores, but the
    // only write path is /api/games/score (Admin SDK, which bypasses these rules after
    // verifying the ID token + clamping the value). With no client `allow write` here, a
    // direct client-SDK setDoc to scores/{gameId} is denied — closing the leaderboard
    // score-tampering gap.
    match /users/{uid}/scores/{gameId} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // gameStats stays client-writable: it still holds the per-game progress/resume
    // blob restored by REQUEST_PROGRESS (S2-b — lock once a server progress API exists).
    // The leaderboard-relevant weighted stats are also written here by the score route.
    match /users/{uid}/gameStats/{statsId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Any other owner subcollection (allowlist fallback).
    match /users/{uid}/{sub}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // User profiles are readable by anyone (for leaderboards, profile viewing).
    // Owners may create/update their own profile but may NOT set or change `role`;
    // only an existing admin can assign roles.
    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid &&
        (!('role' in request.resource.data) || request.resource.data.role != 'admin');
      allow update: if request.auth != null && (
        (request.auth.uid == uid && noPrivilegeEscalation()) ||
        isAdmin()
      );
    }

    // OAuth provider -> account links. Managed exclusively by the server via the
    // Admin SDK (which bypasses these rules); clients must never read or write them.
    match /oauthLinks/{linkId} {
      allow read, write: if false;
    }

    // Usernames lookup - readable by anyone, writable by the owner
    match /usernames/{username} {
      allow read: if true;
      // Create only a username doc that points at the caller's own uid — otherwise
      // any authed user could squat names (or forge an entry pointing at a victim),
      // bypassing claimUsername. Update/delete remain restricted to the current owner.
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Allow collection group queries for leaderboard
    match /{path=**}/scores/{gameId} {
      allow read: if true;
    }

    match /{path=**}/gameStats/{statsId} {
      allow read: if true;
    }

    // Games registry - readable by anyone, writable by admins
    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Platform stats - readable by anyone, writable by admins
    match /platform/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Announcements - readable by anyone, writable by admins
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Game visibility - readable by anyone, writable by admins
    match /gameVisibility/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Game registry - readable by anyone, writable by admins
    match /gameRegistry/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Platform config (e.g. OAuth provider toggles) - readable by anyone, writable by admins
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Materialized leaderboard documents - written only by Admin SDK (server-side), public read
    match /leaderboards/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
