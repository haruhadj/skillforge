rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own data
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // User profiles are readable by anyone (for leaderboards, profile viewing)
    match /users/{uid} {
      allow read: if true;
    }

    // Usernames lookup - readable by anyone
    match /usernames/{username} {
      allow read: if true;
    }

    // Allow collection group queries for leaderboard
    match /{path=**}/scores/{gameId} {
      allow read: if true;
    }

    match /{path=**}/gameStats/{statsId} {
      allow read: if true;
    }

    // Games registry - readable by anyone, writable by admins
    match /games/{gameId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Platform stats - readable by anyone, writable by admins
    match /platform/{docId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Announcements - readable by anyone, writable by admins
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Game visibility - readable by anyone, writable by admins
    match /gameVisibility/{gameId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
