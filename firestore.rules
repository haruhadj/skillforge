rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own data
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // User profiles are readable by anyone (for leaderboards, profile viewing)
    // Allow authenticated users to create their own profile
    // Admins can update any user document (e.g. to assign roles)
    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // OAuth provider -> account links. Managed exclusively by the server via the
    // Admin SDK (which bypasses these rules); clients must never read or write them.
    match /oauthLinks/{linkId} {
      allow read, write: if false;
    }

    // Usernames lookup - readable by anyone, writable by the owner
    match /usernames/{username} {
      allow read: if true;
      // Allow write if: user is authenticated AND (creating new OR owns this username)
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Allow collection group queries for leaderboard
    match /{path=**}/scores/{gameId} {
      allow read: if true;
    }

    match /{path=**}/gameStats/{statsId} {
      allow read: if true;
    }

    // Games registry - readable by anyone, writable by admins
    match /games/{gameId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Platform stats - readable by anyone, writable by admins
    match /platform/{docId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Announcements - readable by anyone, writable by admins
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Game visibility - readable by anyone, writable by admins
    match /gameVisibility/{gameId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Game registry - readable by anyone, writable by admins
    match /gameRegistry/{gameId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Platform config (e.g. OAuth provider toggles) - readable by anyone, writable by admins
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
