rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // True only when the *caller* already holds the admin role. Reads the caller's
    // own user doc, so it cannot be spoofed by writing the target document.
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // True when the incoming write does not touch privileged fields. `role` is the
    // sole admin marker (see app/api/admin/delete-user/route.ts) and must never be
    // self-assignable; gate any future privilege fields here too.
    function noPrivilegeEscalation() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
    }

    // Owner subcollection access. These matches require at least one path segment
    // below users/{uid}, so they can never grant write access to the root profile doc
    // — that is governed solely by the `match /users/{uid}` block below, which guards
    // the `role` field. Without this separation, a recursive `{document=**}` rule would
    // let any signed-in user write `role: 'admin'` onto their own profile.
    //
    // S2: scores are SERVER-AUTHORITATIVE. The client may read its own scores, but the
    // only write path is /api/games/score (Admin SDK, which bypasses these rules after
    // verifying the ID token + clamping the value). With no client `allow write` here, a
    // direct client-SDK setDoc to scores/{gameId} is denied — closing the leaderboard
    // score-tampering gap.
    match /users/{uid}/scores/{gameId} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // S2-b: gameStats is SERVER-AUTHORITATIVE, like scores above. The owner may read it,
    // but there is NO client write rule. The weighted leaderboard stats are written by
    // /api/games/score and the per-game resume blob (under `progress`) by
    // /api/games/progress — both Admin SDK, which bypass these rules after verifying the
    // token. This closes the last client write path into the leaderboard's inputs
    // (totalMatchCount feeds the composite + popularity ranking).
    match /users/{uid}/gameStats/{statsId} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // Any other owner subcollection: READ-ONLY. Firestore grants a write if ANY match
    // allows it, so a permissive `{document=**}` write here would re-grant client writes
    // to scores/{gameId} and gameStats/{statsId} above (defeating S2 / S2-b). No client
    // path writes any owner subcollection other than via the Admin SDK score/progress
    // routes; recentlyPlayed lives on the root profile doc, not a subcollection.
    match /users/{uid}/{sub}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // R14: the user profile doc carries PII (email, linkedProviders OAuth emails,
    // device fingerprints) and the `role` admin marker, so it is NO LONGER public.
    // Read is restricted to the owner and admins. Public display data (username +
    // photo) lives in publicProfiles/{uid} below, which the leaderboard / activity /
    // profile viewer read instead. isAdmin() uses get(), which is exempt from read
    // rules, so this restriction does not break the admin check itself; admins can
    // still list the users collection (the rule is uid-independent), non-admins
    // cannot — closing the mass email-enumeration hole (adminService getAllUsers).
    // Owners may create/update their own profile but may NOT set or change `role`;
    // only an existing admin can assign roles.
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid &&
        (!('role' in request.resource.data) || request.resource.data.role != 'admin');
      allow update: if request.auth != null && (
        (request.auth.uid == uid && noPrivilegeEscalation()) ||
        isAdmin()
      );
    }

    // R14: public, display-only mirror of a user (username + photo). World-readable
    // so leaderboards / activity / profile viewing never touch the PII-locked
    // users/{uid} doc. The owner-write rule uses hasOnly([...]) to guarantee email,
    // role, linkedProviders, and device fields can NEVER be written here, even by a
    // buggy or malicious client. Synced from users/{uid} by syncPublicProfile().
    match /publicProfiles/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == uid &&
        request.resource.data.keys().hasOnly(
          ['username', 'usernameNormalized', 'photoURL', 'photoThumbURL', 'updatedAt']);
    }

    // OAuth provider -> account links. Managed exclusively by the server via the
    // Admin SDK (which bypasses these rules); clients must never read or write them.
    match /oauthLinks/{linkId} {
      allow read, write: if false;
    }

    // Usernames lookup - readable by anyone, writable by the owner
    match /usernames/{username} {
      allow read: if true;
      // Create only a username doc that points at the caller's own uid — otherwise
      // any authed user could squat names (or forge an entry pointing at a victim),
      // bypassing claimUsername. Update/delete remain restricted to the current owner.
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Allow collection group queries for leaderboard
    match /{path=**}/scores/{gameId} {
      allow read: if true;
    }

    match /{path=**}/gameStats/{statsId} {
      allow read: if true;
    }

    // Games registry - readable by anyone, writable by admins
    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Platform stats - readable by anyone, writable by admins
    match /platform/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Announcements - readable by anyone, writable by admins
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Game visibility - readable by anyone, writable by admins
    match /gameVisibility/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Game registry - readable by anyone, writable by admins
    match /gameRegistry/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Platform config (e.g. OAuth provider toggles) - readable by anyone, writable by admins
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Materialized leaderboard documents - written only by Admin SDK (server-side), public read
    match /leaderboards/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // R17: cached admin analytics (platform stats + learning-gap report). The report
    // embeds PII-derived data (at-risk students with email), so it is Admin-SDK only —
    // clients reach it solely through the admin-gated /api/admin/* routes, never directly.
    match /adminCache/{docId} {
      allow read, write: if false;
    }

    // R17: cached global activity feed. Written by Admin SDK; clients read the public
    // /api/activity route (IP-rate-limited), not the doc directly.
    match /activityCache/{docId} {
      allow read, write: if false;
    }
  }
}
